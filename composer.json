{
    "name": "sanvex/ecosystem",
    "description": "An AI-agentic ecosystem and unified API integration layer for Laravel",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*"
        },
        {
            "type": "path",
            "url": "packages/drivers/*"
        }
    ],
    "autoload": {
        "psr-4": {
            "Sanvex\\Core\\": "packages/core/src/",
            "Sanvex\\Cli\\": "packages/cli/src/",
            "Sanvex\\Mcp\\": "packages/mcp/src/",
            "Sanvex\\Drivers\\Gmail\\": "packages/drivers/gmail/src/",
            "Sanvex\\Drivers\\GitHub\\": "packages/drivers/github/src/",
            "Sanvex\\Drivers\\Linear\\": "packages/drivers/linear/src/",
            "Sanvex\\Drivers\\Notion\\": "packages/drivers/notion/src/",
            "Sanvex\\Drivers\\Slack\\": "packages/drivers/slack/src/"
        }
    }
}
