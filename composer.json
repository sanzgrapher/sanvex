{
    "name": "sanvex/monorepo",
    "description": "sanvex - AI agent integration layer for Laravel 13",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "sanvex/core": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpunit/phpunit": "^11.0"
    },
    "repositories": [
        {"type": "path", "url": "packages/core"},
        {"type": "path", "url": "packages/drivers/slack"},
        {"type": "path", "url": "packages/drivers/github"},
        {"type": "path", "url": "packages/drivers/gmail"},
        {"type": "path", "url": "packages/drivers/linear"},
        {"type": "path", "url": "packages/drivers/notion"},
        {"type": "path", "url": "packages/cli"},
        {"type": "path", "url": "packages/mcp"}
    ],
    "autoload": {
        "psr-4": {}
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest"
    }
}
