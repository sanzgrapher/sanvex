{
    "name": "sanvex/github",
    "description": "GitHub driver for sanvex",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "sanvex/core": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Sanvex\\Drivers\\GitHub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sanvex\\Drivers\\GitHub\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Sanvex\\Drivers\\GitHub\\GitHubServiceProvider"]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
